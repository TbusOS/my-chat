# ============================================
# Mac Mini AI Stack - 环境变量配置
# ============================================
# 使用方法：cp .env.example .env && vim .env

# === 容器运行时 ===
# Docker Desktop 用户：注释掉 HOST_IP（默认用 host.docker.internal）
# Colima 用户：取消注释并填入宿主机 IP（运行 colima ls 查看）
# HOST_IP=192.168.106.1

# === Ollama 配置 ===
OLLAMA_PORT=11434
OLLAMA_MODELS=qwen2.5:7b,llama3.1:8b

# === PostgreSQL ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=lobechat
POSTGRES_PORT=5432

# === Redis ===
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379

# === LobeChat ===
# 如果需要使用云端 API（可选）
OPENAI_API_KEY=sk-placeholder

# === 飞书 Bot（可选） ===
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
